{
  "name": "LoopOver Review → Slack",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "loopover-review",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-review",
      "name": "LoopOver review webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 0],
      "webhookId": "loopover-review"
    },
    {
      "parameters": {
        "channel": "#reviews",
        "text": "=Review {{ $json.body.verdict ?? $json.verdict ?? 'unknown' }} for {{ $json.body.repo ?? $json.repo ?? 'repo' }} PR #{{ $json.body.prNumber ?? $json.prNumber ?? '?' }}",
        "otherOptions": {}
      },
      "id": "slack-notify",
      "name": "Post to Slack",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [320, 0],
      "credentials": {
        "slackApi": {
          "id": "CONFIGURE_SLACK_CREDENTIAL",
          "name": "Slack account"
        }
      }
    }
  ],
  "connections": {
    "LoopOver review webhook": {
      "main": [
        [
          {
            "node": "Post to Slack",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "pinData": {},
  "meta": {
    "templateCredsSetupCompleted": false,
    "instanceId": "loopover-review-slack-notify"
  }
}
